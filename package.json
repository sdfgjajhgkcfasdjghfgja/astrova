{
  "name": "pulseguard",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "packages/electron/main.cjs",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build --config packages/frontend/vite.config.ts && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "start:prod": "node dist/server.cjs",
    "demo": "npm run dev",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "test:smoke": "node tests/smoke.test.js",
    "test:python": "pytest --cov=packages/backend/anomaly_engine --cov=packages/simulators tests/",
    "test:vitest": "vitest run --coverage",
    "test": "npm run test:python && npm run test:vitest",
    "electron:dev": "concurrently -k \"npm run dev\" \"ELECTRON_DEV_MODE=true wait-on http://localhost:${PORT:-3000} && electron .\"",
    "electron:build": "npm run electron:package",
    "electron:package": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.pulseguard.platform",
    "productName": "PulseGuard Industrial IoT Platform",
    "directories": {
      "output": "dist-desktop"
    },
    "files": [
      "dist/**/*",
      "packages/electron/**/*",
      "package.json"
    ],
    "publish": {
      "provider": "github",
      "owner": "alikutluay543",
      "repo": "pulseguard-industrial-iot"
    },
    "win": {
      "target": "portable",
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.utilities"
    },
    "linux": {
      "target": "AppImage",
      "category": "Utility"
    }
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@influxdata/influxdb-client": "^1.35.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "@xyflow/react": "^12.11.2",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "electron-updater": "^6.8.9",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "pdf-parse": "^2.4.5",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "recharts": "^3.9.2",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "three": "^0.185.1",
    "vite": "^6.2.3",
    "winston": "^3.19.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.14.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/three": "^0.185.0",
    "@vitest/coverage-v8": "^4.1.10",
    "autoprefixer": "^10.4.21",
    "concurrently": "^10.0.3",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.25.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vitest": "^4.1.10",
    "wait-on": "^9.0.10"
  }
}
