{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "start:prod": "node dist/server.cjs",
    "demo": "npm run dev",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "test:smoke": "node tests/smoke.test.js",
    "test:python": "python3 -m unittest discover -s tests -p 'test_*.py'",
    "test:parity": "tsx tests/test_parity.ts",
    "test": "npm run build && npm run test:python && npm run test:parity && npm run test:smoke",
    "electron:dev": "concurrently -k \"npm run dev\" \"ELECTRON_DEV_MODE=true wait-on http://localhost:${PORT:-3000} && electron .\"",
    "electron:build": "npm run electron:package",
    "electron:package": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.tharion.spectrum",
    "productName": "Astrova Spectral Analyzer",
    "directories": {
      "output": "dist-desktop"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": "portable",
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.utilities"
    },
    "linux": {
      "target": "AppImage",
      "category": "Utility"
    }
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@influxdata/influxdb-client": "^1.35.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "pdf-parse": "^2.4.5",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "satellite.js": "^4.1.4",
    "three": "^0.185.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/three": "^0.185.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^10.0.3",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "wait-on": "^9.0.10"
  }
}
